// helper: ambil sample random dari array (unique)
function pickRandomUnique<T>(arr: T[], count: number): T[] {
  if (count <= 0) return [];
  if (count >= arr.length) return [...arr];
  const picked: T[] = [];
  const used = new Set<number>();
  while (picked.length < count) {
    const idx = randInt(0, arr.length - 1);
    if (used.has(idx)) continue;
    used.add(idx);
    picked.push(arr[idx]);
  }
  return picked;
}

function generateNikFromBirthAndGender(
  birthDateStr: string | null | undefined,
  genderStr: string | null | undefined,
  counter: number
): string {
  const wilayah = "357301"; // kode wilayah dummy (Malang)

  // 1) Tentukan gender (kalau kosong, random L/P)
  let gender = (genderStr || "").toUpperCase().trim();
  if (gender !== "L" && gender !== "P") {
    gender = Math.random() < 0.5 ? "L" : "P";
  }

  // 2) Tentukan tanggal lahir (kalau kosong/invalid, random)
  let birth = birthDateStr ? new Date(birthDateStr) : new Date(NaN);

  if (isNaN(birth.getTime())) {
    const now = new Date();
    const minAge = 22;
    const maxAge = 60;
    const age = randInt(minAge, maxAge);
    const year = now.getFullYear() - age;
    const month = randInt(1, 12);
    const day = randInt(1, 28);

    birth = new Date(year, month - 1, day);
  }

  const day = birth.getDate();
  const month = birth.getMonth() + 1;
  const year = birth.getFullYear() % 100;

  let dd = String(day).padStart(2, "0");
  const mm = String(month).padStart(2, "0");
  const yy = String(year).padStart(2, "0");

  if (gender === "P") {
    const dayNum = Number(dd);
    dd = String(dayNum + 40).padStart(2, "0");
  }

  const urut = String(counter % 10000).padStart(4, "0");

  return `${wilayah}${dd}${mm}${yy}${urut}`;
}

