function randInt(min: number, max: number) {
  return Math.floor(Math.random() * (max - min + 1)) + min;
}

function randomPastDate(maxDaysAgo: number) {
  const now = new Date();
  const d = new Date(now);
  d.setDate(d.getDate() - randInt(0, maxDaysAgo));
  return d;
}

