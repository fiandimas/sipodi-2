    if (u.schoolNpsn) adminSekolahByNpsn.set(u.schoolNpsn, u.id);
  }

  console.log("👤 Upsert admin talenta semua bidang...");
  const multiAdminUsername = "admintalenta_all";
  const multiAdmin = await prisma.user.upsert({
    where: { username: multiAdminUsername },
    update: {
      name: "Admin Talenta Semua Bidang",
      role: UserRole.ADMIN_TALENTA,
      branchId: branch.id,
      schoolNpsn: null,
      gtkNik: null,
      isActive: true,
      password: sha256(PASSWORD_ADMIN_TALENTA),
      passwordAlgo: PasswordAlgo.SHA256,
    },
    create: {
      username: multiAdminUsername,
      name: "Admin Talenta Semua Bidang",
      role: UserRole.ADMIN_TALENTA,
      branchId: branch.id,
      schoolNpsn: null,
      gtkNik: null,
      isActive: true,
      password: sha256(PASSWORD_ADMIN_TALENTA),
      passwordAlgo: PasswordAlgo.SHA256,
    },
    select: { id: true },
  });

  for (const f of fieldsAll) {
    await prisma.userTalentField.upsert({
      where: { userId_fieldId: { userId: multiAdmin.id, fieldId: f.id } },
      update: {},
      create: { userId: multiAdmin.id, fieldId: f.id },
    });
  }
  console.log("✅ Admin talenta semua bidang selesai");

  const talentaRater = { id: multiAdmin.id };

  // ===== GTK =====
  console.log("👥 (Dev) Bersihkan GTK & user GTK lama...");
  await prisma.user.deleteMany({ where: { role: UserRole.USER_GTK } });
  await prisma.gtk.deleteMany({});
  console.log("✅ Data GTK lama dibersihkan");

  type GtkSeed = {
    nik: string;
    name: string;
    email: string;
    schoolNpsn: string;
    type: GtkType;
    mapel?: string | null;

    nuptk?: string | null;
    nip?: string | null;
    gender?: "L" | "P" | null;
    birthDate?: Date | null;
  };

  const allGtk: GtkSeed[] = [];

  console.log(`👥 Load GTK dari mapping.json: ${gtkMapping.length} file`);

  for (const item of gtkMapping) {
    if (!item.schoolNpsn) {
      console.warn(`⚠️ mapping kosong (schoolNpsn): ${item.file}`);
      continue;
    }

    const filePath = path.join(process.cwd(), item.file); // item.file sudah relatif root
    const gtkRows = loadSheetRows(filePath);
    if (!gtkRows.length) continue;

    const schoolNpsn = item.schoolNpsn;

    // Validasi sekolah ada (biar mapping salah cepat ketahuan)
    const schoolExists = await prisma.school.findUnique({
      where: { npsn: schoolNpsn },
      select: { npsn: true },
    });
    if (!schoolExists) {
      console.warn(`⚠️ NPSN tidak ada di tabel School: ${schoolNpsn} (file ${item.file})`);
      continue;
    }

    for (const r of gtkRows) {
      const name = pick(r, ["Nama Lengkap", "NAMA LENGKAP", "Nama", "NAMA"]);
      if (!name) continue;

      // WAJIB: pakai NIK asli dari Excel
      const nik = toNull(pick(r, ["NIK", "Nik"]));
      if (!nik) continue;

      const nuptk = toNull(pick(r, ["NUPTK", "Nuptk"]));
      const nip = toNull(pick(r, ["NIP", "Nip"]));

      const genderRaw = toNull(pick(r, ["L/P", "L_P", "JK", "Jenis Kelamin"]));
      const gender = genderRaw === "L" || genderRaw === "P" ? (genderRaw as "L" | "P") : null;

      const birthDateStr = toNull(pick(r, ["Tanggal Lahir", "TANGGAL LAHIR", "Tgl Lahir"]));
      let birthDate: Date | null = null;
      if (birthDateStr) {
        const d = new Date(birthDateStr);
        if (!isNaN(d.getTime())) birthDate = d;
      }

      const jenisPtk = pick(r, ["Jenis PTK", "JENIS PTK", "Jenis"]);
      const jabatanPtk = pick(r, ["Jabatan PTK", "JABATAN PTK", "Jabatan"]);
      const type = deriveJenisGtk(jenisPtk, jabatanPtk);
      const mapel = deriveMapel(jabatanPtk, type);

      const safeName =
        (name || "gtk")
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, ".")
          .replace(/^\.+|\.+$/g, "") || "gtk";

      // Email unik & deterministik
      const email = `${safeName}.${nik}@${schoolNpsn}.example.com`.toLowerCase();

      allGtk.push({
        nik,
        name,
        email,
        schoolNpsn,
        type,
        mapel,
        nuptk,
        nip,
        gender,
        birthDate,
      });
    }
  }

  // Dedup by nik (PK Gtk)
  const byNik = new Map<string, GtkSeed>();
  for (const g of allGtk) if (!byNik.has(g.nik)) byNik.set(g.nik, g);
  const gtkFinal = [...byNik.values()];
  console.log(`✅ GTK final setelah dedup nik: ${gtkFinal.length}`);

  // insert GTK + user
  console.log("💾 Upsert GTK + user GTK...");
  for (const g of gtkFinal) {
    const gtk = await prisma.gtk.upsert({
      where: { nik: g.nik },
      update: {
        name: g.name,
        email: g.email,
        schoolNpsn: g.schoolNpsn,
        mapel: g.mapel ?? undefined,
        type: g.type,
        nuptk: g.nuptk ?? undefined,
        nip: g.nip ?? undefined,
        gender: g.gender ?? undefined,
        birthDate: g.birthDate ?? undefined,
      },
      create: {
        nik: g.nik,
        name: g.name,
        email: g.email,
        schoolNpsn: g.schoolNpsn,
        mapel: g.mapel ?? undefined,
        type: g.type,
        nuptk: g.nuptk ?? undefined,
        nip: g.nip ?? undefined,
        gender: g.gender ?? undefined,
        birthDate: g.birthDate ?? undefined,
      },
      select: { nik: true, name: true, schoolNpsn: true },
    });

    const username = `gtk_${gtk.nik}`;

    await prisma.user.upsert({
      where: { gtkNik: gtk.nik },
      update: {
        username,
        name: gtk.name,
        role: UserRole.USER_GTK,
        isActive: true,
        schoolNpsn: gtk.schoolNpsn,
        branchId: branch.id,
        password: sha256(gtk.nik),
        passwordAlgo: PasswordAlgo.SHA256,
      },
      create: {
        username,
        name: gtk.name,
        role: UserRole.USER_GTK,
        isActive: true,
        gtkNik: gtk.nik,
        schoolNpsn: gtk.schoolNpsn,
        branchId: branch.id,
        password: sha256(gtk.nik),
        passwordAlgo: PasswordAlgo.SHA256,
      },
    });
  }
  console.log(`✅ Total GTK di-UPSERT: ${gtkFinal.length}`);

  // ===== master data untuk seed submission =====
  console.log("📚 Load master type/field/category/sub/tag...");
  const types = await prisma.talentType.findMany({ select: { id: true, name: true } });
  const fields = await prisma.talentField.findMany({ select: { id: true } });
  const categories = await prisma.talentCategory.findMany({ select: { id: true, fieldId: true } });
  const subCategories = await prisma.talentSubCategory.findMany({ select: { id: true, categoryId: true } });

  const tags = await prisma.talentTag.findMany({
    where: { isActive: true },
    select: { id: true, subCategoryId: true },
  });

  const tagsBySub = new Map<string, string[]>();
  for (const t of tags) {
    const arr = tagsBySub.get(t.subCategoryId) ?? [];
    arr.push(t.id);
    tagsBySub.set(t.subCategoryId, arr);
  }

  const juaraTags = await prisma.talentTag.findMany({
    where: { isActive: true, name: { in: ["Juara 1", "Juara 2", "Juara 3"] } },
    select: { id: true, subCategoryId: true },
  });

  const juaraBySub = new Map<string, string[]>();
  for (const t of juaraTags) {
    const arr = juaraBySub.get(t.subCategoryId) ?? [];
    arr.push(t.id);
    juaraBySub.set(t.subCategoryId, arr);
  }

  console.log(
    `✅ talentType: ${types.length}, talentField: ${fields.length}, category: ${categories.length}, subCategory: ${subCategories.length}, tag: ${tags.length}`
  );

  // ===== seed submissions + keputusan sekolah + review tahap-2 (TALENTA/SUPER_ADMIN override) =====
  console.log("📝 Seed talentSubmission (connect tags + tagsOtherText) + keputusan SEKOLAH + review tahap-2...");

  if (types.length && fields.length && categories.length && gtkFinal.length) {
    await prisma.talentScoreEntry.deleteMany({});
    await prisma.talentSubmission.deleteMany({});

    const MAX_DAYS = 365;
    const COUNT_PER_GTK = 10;
    const MAX_TAGS = 20;

    const createdApprovedIds: string[] = [];

    for (const gtk of gtkFinal) {
      for (let i = 0; i < COUNT_PER_GTK; i++) {
        const createdAt = randomPastDate(MAX_DAYS);

        // status hasil sekolah
        const roll = randInt(1, 3);
        let status: TalentSubmissionStatus = TalentSubmissionStatus.PENDING;
        if (roll === 1) status = TalentSubmissionStatus.APPROVED;
        if (roll === 2) status = TalentSubmissionStatus.REJECTED;

        const pickedType = types[randInt(0, types.length - 1)];
        const jenisScore = jenisScoreByTypeName(pickedType.name);

        const userScore = randInt(1, 100);

        // pick field/category/subcategory
        let pickedFieldId = randInt(1, 2) === 1 ? firstField.id : fields[randInt(0, fields.length - 1)].id;

        let categoriesForField = categories.filter((c) => c.fieldId === pickedFieldId);
        let pickedCategory =
          categoriesForField.length > 0
            ? categoriesForField[randInt(0, categoriesForField.length - 1)]
            : categories[randInt(0, categories.length - 1)];

        if (categoriesForField.length === 0) pickedFieldId = pickedCategory.fieldId;

        const subForCat = subCategories.filter((x) => x.categoryId === pickedCategory.id);
        const pickedSubCategoryId = subForCat.length ? subForCat[randInt(0, subForCat.length - 1)].id : null;

        // ===== tags (relational first, fallback otherText) =====
        let tagIds: string[] = [];
        let tagsOtherText: string[] = [];

        const desiredTotalTags = clamp(randInt(1, 5), 1, MAX_TAGS);

        if (pickedSubCategoryId) {
          // ambil beberapa tag random dari subCategory ini
          const pool = tagsBySub.get(pickedSubCategoryId) ?? [];
          if (pool.length) {
            const take = clamp(
              randInt(1, Math.min(desiredTotalTags, pool.length)),
              1,
              pool.length
            );
            tagIds = pickRandomUnique(pool, take);
          }

          // WAJIB: selalu pakai Juara 1/2/3 untuk subCategory ini
          const juaraPool = juaraBySub.get(pickedSubCategoryId) ?? [];
          if (juaraPool.length) {
            const juaraId = juaraPool[randInt(0, juaraPool.length - 1)];
            if (!tagIds.includes(juaraId) && tagIds.length < MAX_TAGS) {
              tagIds.unshift(juaraId);
            }
          }
        }

        // fallback kalau subCategoryId null atau tidak ada tag sama sekali
        if (!tagIds.length) {
          tagsOtherText = Array.from({ length: desiredTotalTags }).map(
            (_, k) => `TAG_BEBAS_${k + 1}`
          );
        } else {
          const extraOther = randInt(0, 2);
          tagsOtherText = Array.from({ length: extraOther }).map(
            (_, k) => `TAG_BEBAS_${k + 1}`
          );
        }

        const totalTags = clamp(tagIds.length + tagsOtherText.length, 1, MAX_TAGS);
        const tagScore = totalTags * 5;

        const adminScore = 0;
        const computedScore = computeScore({ userScore, tagScore, jenisScore, adminScore });

        // ===== keputusan SEKOLAH (siapa yg approve/reject) =====
        const schoolAdminId = adminSekolahByNpsn.get(gtk.schoolNpsn) ?? null;

        let approvedAt: Date | null = null;
        let rejectedAt: Date | null = null;

        if (status === TalentSubmissionStatus.APPROVED) {
          approvedAt = new Date(createdAt);
          approvedAt.setDate(approvedAt.getDate() + randInt(0, 14));
        }
        if (status === TalentSubmissionStatus.REJECTED) {
          rejectedAt = new Date(createdAt);
          rejectedAt.setDate(rejectedAt.getDate() + randInt(0, 14));
        }

        const created = await prisma.talentSubmission.create({
          data: {
            gtkNik: gtk.nik,
            typeId: pickedType.id,
            fieldId: pickedFieldId,
            categoryId: pickedCategory.id,
            subCategoryId: pickedSubCategoryId,

            activityName: `Kegiatan ${gtk.name} #${i + 1}`,
            organizer: "Organisasi Contoh",
            description: `Deskripsi kegiatan ke-${i + 1} untuk ${gtk.name}`,
            linkPendukung: i % 3 === 0 ? "https://example.com/bukti" : null,

            status,
            createdAt,

            userScore,
            tagScore,
            jenisScore,
            adminScore,
            computedScore,

            tagsOtherText,
            ...(tagIds.length ? { tags: { connect: tagIds.map((id) => ({ id })) } } : {}),

            ...(status === TalentSubmissionStatus.APPROVED
              ? {
                approvedScope: DecisionScope.SEKOLAH,
                approvedById: schoolAdminId,
                approvedAt,
                approvalNote: "Seed: APPROVE(SEKOLAH)",
              }
              : {}),

            ...(status === TalentSubmissionStatus.REJECTED
              ? {
                rejectedScope: DecisionScope.SEKOLAH,
                rejectedById: schoolAdminId,
                rejectedAt,
                rejectionNote: "Seed: REJECT(SEKOLAH)",
                adminScore: null,
                computedScore: null,
              }
              : {}),
          },
          select: { id: true },
        });

        // audit log sekolah
        if (status === TalentSubmissionStatus.APPROVED) {
          await prisma.talentScoreEntry.create({
            data: {
              submissionId: created.id,
              type: ScoreEntryType.ADJUSTMENT,
              points: 0,
              createdById: schoolAdminId,
              note: "APPROVE(SEKOLAH): Seed",
            },
          });
          createdApprovedIds.push(created.id);
        } else if (status === TalentSubmissionStatus.REJECTED) {
          await prisma.talentScoreEntry.create({
            data: {
              submissionId: created.id,
              type: ScoreEntryType.ADJUSTMENT,
              points: 0,
              createdById: schoolAdminId,
              note: "REJECT(SEKOLAH): Seed",
            },
          });
        }
      }
    }

    console.log(`✅ talentSubmission dibuat (loop create): ${gtkFinal.length * COUNT_PER_GTK}`);

    // ===== Review tahap-2: TALENTA atau SUPER_ADMIN (setara, boleh override) =====
    // Yang diatur:
    // - Tidak semua submission lolos sekolah direview (sebagian tetap approved oleh sekolah saja)
    // - Dari yang direview: 60% diputus TALENTA, 40% diputus SUPER_ADMIN
    // - Approve/reject random (bisa Anda atur persentasenya)
    // - Override boleh (bisa timpa keputusan tahap-2 sebelumnya), tapi tetap tidak wajib untuk semua
    if (talentaRater?.id && superadmin?.id) {
      const P_REVIEW = 0.7;          // 70% dari yang lolos sekolah akan direview tahap-2
      const P_TALENTA = 0.6;         // 60% keputusan tahap-2 oleh TALENTA, 40% oleh SUPER_ADMIN
      const P_APPROVE = 0.6;         // random approve/reject pada tahap-2
      const P_OVERRIDE_EXTRA = 0.35; // peluang ada 1x timpa lagi setelah keputusan pertama

      async function applyDecision(params: {
        submissionId: string;
        actorId: string;
        actorScope: DecisionScope;
        action: "APPROVE" | "REJECT";
        label: string;
      }) {
        const { submissionId, actorId, actorScope, action, label } = params;

        const base = await prisma.talentSubmission.findUnique({
          where: { id: submissionId },
          select: { userScore: true, tagScore: true, jenisScore: true },
        });
        if (!base) return;

        if (action === "APPROVE") {
          const adminScore = randInt(0, 100);
          const computedScore = computeScore({
            userScore: base.userScore ?? 0,
            tagScore: base.tagScore ?? 0,
            jenisScore: base.jenisScore ?? 0,
            adminScore,
          });

          await prisma.talentSubmission.update({
            where: { id: submissionId },
            data: {
              // jika sebelumnya sempat REJECT oleh tahap-2, boleh balik approve
              status: TalentSubmissionStatus.APPROVED,

              adminScore,
              computedScore,

              approvedScope: actorScope,
              approvedById: actorId,
              approvedAt: new Date(),
              approvalNote: `${label}: approved by ${actorScope}`,

              // IMPORTANT: override reject sebelumnya
              rejectedScope: null,
              rejectedById: null,
              rejectedAt: null,
              rejectionNote: null,
            },
          });

          await prisma.talentScoreEntry.create({
            data: {
              submissionId,
              type: ScoreEntryType.APPROVAL_SCORE,
              points: Math.round(adminScore),
              createdById: actorId,
              note: `${label}: APPROVAL_SCORE by ${actorScope}`,
            },
          });
        } else {
          await prisma.talentSubmission.update({
            where: { id: submissionId },
            data: {
              status: TalentSubmissionStatus.REJECTED,

              rejectedScope: actorScope,
              rejectedById: actorId,
              rejectedAt: new Date(),
              rejectionNote: `${label}: rejected by ${actorScope}`,

              // IMPORTANT: override approve sebelumnya
              approvedScope: null,
              approvedById: null,
              approvedAt: null,
              approvalNote: null,

              // reset skor final
              adminScore: null,
              computedScore: null,
            },
          });

          await prisma.talentScoreEntry.create({
            data: {
              submissionId,
              type: ScoreEntryType.ADJUSTMENT,
              points: 0,
              createdById: actorId,
              note: `${label}: REJECT by ${actorScope}`,
            },
          });
        }
      }

      let reviewedCount = 0;
      let decidedByTalenta = 0;
      let decidedBySuper = 0;

      for (const submissionId of createdApprovedIds) {
        // 1) tidak semua direview tahap-2
        if (Math.random() > P_REVIEW) continue;
        reviewedCount++;

        // 2) pilih aktor keputusan (60/40)
        const pickTalenta = Math.random() < P_TALENTA;
        const actorId1 = pickTalenta ? talentaRater.id : superadmin.id;
        const actorScope1 = pickTalenta ? DecisionScope.TALENTA : DecisionScope.SUPER_ADMIN;
        if (pickTalenta) decidedByTalenta++;
        else decidedBySuper++;

        // 3) keputusan pertama (approve/reject random)
        const action1: "APPROVE" | "REJECT" = Math.random() < P_APPROVE ? "APPROVE" : "REJECT";
        await applyDecision({
          submissionId,
          actorId: actorId1,
          actorScope: actorScope1,
          action: action1,
          label: "Seed STAGE2 #1",
        });

        // 4) optional: 1x override lagi (boleh timpa), aktor juga ikut 60/40
        if (Math.random() < P_OVERRIDE_EXTRA) {
          const pickTalenta2 = Math.random() < P_TALENTA;
          const actorId2 = pickTalenta2 ? talentaRater.id : superadmin.id;
          const actorScope2 = pickTalenta2 ? DecisionScope.TALENTA : DecisionScope.SUPER_ADMIN;

          // override action random lagi (boleh sama/berlawanan)
          const action2: "APPROVE" | "REJECT" = Math.random() < P_APPROVE ? "APPROVE" : "REJECT";

          await applyDecision({
            submissionId,
            actorId: actorId2,
            actorScope: actorScope2,
            action: action2,
            label: "Seed STAGE2 OVERRIDE #2",
          });
        }
      }

      console.log(
        `✅ Review tahap-2 selesai. Direview=${reviewedCount}/${createdApprovedIds.length}, ` +
        `decider TALENTA≈${decidedByTalenta}, SUPER_ADMIN≈${decidedBySuper} (target 60/40).`
      );
    } else {
      console.log("ℹ️ Tidak ada talentaRater atau superadmin, skip review tahap-2.");
    }

  } else {
    console.log("ℹ️ Skip talentSubmission karena master/gtk kosong");
  }

  console.log("🔐 Sinkronisasi default UserAccess untuk semua role...");

  // SUPER_ADMIN
  {
    const superAdmins = await prisma.user.findMany({
      where: { role: UserRole.SUPER_ADMIN },
      select: { id: true },
    });

    for (const u of superAdmins) {
      const exists = await prisma.userAccess.findFirst({
        where: { userId: u.id, role: UserRole.SUPER_ADMIN, branchId: branch.id },
        select: { id: true },
      });

      if (!exists) {
        await prisma.userAccess.create({
          data: {
            userId: u.id,
            role: UserRole.SUPER_ADMIN,
            branchId: branch.id,
            schoolNpsn: null,
          },
        });
      }
    }
  }

  // ADMIN_TALENTA
  {
    const adminsTalenta = await prisma.user.findMany({
      where: { role: UserRole.ADMIN_TALENTA },
      select: { id: true },
    });

    for (const u of adminsTalenta) {
      const exists = await prisma.userAccess.findFirst({
        where: { userId: u.id, role: UserRole.ADMIN_TALENTA, branchId: branch.id },
        select: { id: true },
      });

      if (!exists) {
        await prisma.userAccess.create({
          data: {
            userId: u.id,
            role: UserRole.ADMIN_TALENTA,
            branchId: branch.id,
            schoolNpsn: null,
          },
        });
      }
    }
  }

  // ADMIN_SEKOLAH
  {
    const adminsSekolah = await prisma.user.findMany({
      where: { role: UserRole.ADMIN_SEKOLAH, schoolNpsn: { not: null } },
      select: { id: true, schoolNpsn: true },
    });

    for (const u of adminsSekolah) {
      if (!u.schoolNpsn) continue;

      const exists = await prisma.userAccess.findFirst({
        where: {
          userId: u.id,
          role: UserRole.ADMIN_SEKOLAH,
          branchId: branch.id,
          schoolNpsn: u.schoolNpsn,
        },
        select: { id: true },
      });

      if (!exists) {
        await prisma.userAccess.create({
          data: {
            userId: u.id,
            role: UserRole.ADMIN_SEKOLAH,
            branchId: branch.id,
            schoolNpsn: u.schoolNpsn,
          },
        });
      }
    }
  }

  // USER_GTK
  {
    const gtkUsers = await prisma.user.findMany({
      where: { role: UserRole.USER_GTK, schoolNpsn: { not: null } },
      select: { id: true, schoolNpsn: true },
    });

    for (const u of gtkUsers) {
      if (!u.schoolNpsn) continue;

      const exists = await prisma.userAccess.findFirst({
        where: {
          userId: u.id,
          role: UserRole.USER_GTK,
          branchId: branch.id,
          schoolNpsn: u.schoolNpsn,
        },
        select: { id: true },
      });

      if (!exists) {
        await prisma.userAccess.create({
          data: {
            userId: u.id,
            role: UserRole.USER_GTK,
            branchId: branch.id,
            schoolNpsn: u.schoolNpsn,
          },
        });
      }
    }
  }

  console.log("✅ Sinkronisasi UserAccess selesai");

  console.log("🎉 Seed selesai.");
}

main()
  .catch((e) => {
    console.error("❌ Seed error:", e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
    console.log("🔌 Prisma disconnected");
  });
